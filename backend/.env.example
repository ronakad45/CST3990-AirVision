# ============================================
# AirVision Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)
# ============================================

# OpenAQ API Key (Required)
# Sign up at https://explore.openaq.org to get your key
OPENAQ_API_KEY=your-openaq-api-key-here

# OpenWeather API Key (Optional but recommended)
# Sign up at https://openweathermap.org/api for a free key
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Database
DATABASE_URL=sqlite:///data/airvision.db

# JWT Secret for authentication (change this to a random string)
JWT_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Target Cities (comma-separated)
TARGET_CITIES=Dubai,Abu Dhabi,Riyadh

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True
